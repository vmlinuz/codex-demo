{
  "name": "codex-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --webpack",
    "build": "next build",
    "start": "bun --bun next start",
    "migrate": "bun run scripts/migrate.ts",
    "test": "bun run test:unit",
    "test:all": "bun run test:unit && bun run test:e2e",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run --configLoader native",
    "test:unit:watch": "node ./node_modules/vitest/vitest.mjs --configLoader native",
    "test:e2e": "bun run build && node ./tests/e2e/run-all.mjs",
    "test:e2e:playwright": "node ./node_modules/playwright/cli.js test",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "dependencies": {
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "better-auth": "^1.6.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.11",
    "eslint": "^10.0.0",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
